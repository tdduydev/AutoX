# ─── LLM Provider ────────────────────────────────────────
LLM_PROVIDER=openai          # openai | anthropic | ollama | google | groq | mistral
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# ─── Provider API Keys ──────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# ─── Ollama (Local) ─────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ─── Server / Gateway ───────────────────────────────────
PORT=18789
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Database ────────────────────────────────────────────
DATABASE_URL=postgresql://xclaw:xclaw@localhost:5451/xclaw
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# ─── Agent ───────────────────────────────────────────────
AGENT_PERSONA=You are xClaw, a helpful AI assistant with access to various tools and skills.
MAX_TOOL_ITERATIONS=10
TOOL_TIMEOUT=30000

# ─── Memory ──────────────────────────────────────────────
MEMORY_ENABLED=true
MAX_HISTORY=20

# ─── Channels (optional) ────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# ─── Data ────────────────────────────────────────────────
DATA_DIR=./data
